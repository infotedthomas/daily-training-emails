# Copy to .dev.vars for local testing (wrangler dev)
# Never commit .dev.vars to git.

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
KIT_API_KEY=your-kit-v4-api-key
ADMIN_TOKEN=some-long-random-string
# AI uses the Workers AI binding (no key). For `wrangler dev`, add: AI = ... is not needed;
# wrangler proxies Workers AI to your account automatically when logged in.
